# NexoBank Backend — environment variables template
# Copy this file to .env and fill in REAL values before running.
# Never commit .env to version control.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/nexobank
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=nexobank

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT / Auth ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Internal API ──────────────────────────────────────────────────────────────
# Used by internal services calling /internal/* endpoints
INTERNAL_API_KEY=your-internal-api-key-here

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
